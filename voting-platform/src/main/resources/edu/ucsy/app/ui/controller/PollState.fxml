<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-root" stylesheets="@css/application.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.ucsy.app.ui.controller.PollState">
    <VBox alignment="TOP_CENTER" spacing="30" styleClass="page-root">
        <padding>
            <Insets bottom="40" left="60" right="60" top="40" />
        </padding>
        <VBox maxWidth="800" spacing="25" styleClass="card">
            <VBox alignment="CENTER" spacing="10">
                <Label style="-fx-text-fill: #3498db; -fx-font-weight: bold; -fx-font-size: 14px;" text="CURRENT POLL" />
                <Label fx:id="ipAddressLabel" text="IP Address" />
                <Label fx:id="pollTitleLabel" style="-fx-font-size: 24px;" styleClass="title" text="Who should be the next Student Council President?" wrapText="true" />
                <Label fx:id="pollDescriptionLabel" styleClass="subtitle" text="Please select one candidate from the list below." textAlignment="CENTER" wrapText="true" />
            </VBox>

            <Separator />

            <VBox fx:id="optionsContainer" spacing="15">
            <children>
                <HBox spacing="10" styleClass="option-row">
                    <children>
                        <Label styleClass="option-title" text="Option A" />
                     <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="option-votes" text="25 votes" />
                    </children>
                </HBox>            </children>
            </VBox>

            <HBox alignment="CENTER" spacing="15">
                <Button onAction="#closePoll" prefWidth="200" styleClass="primary-btn" text="Close Poll" />
            </HBox>
        </VBox>

        <Label style="-fx-text-fill: #e67e22; -fx-font-weight: bold;" text="Voting ends at: 02:45:10" />

    </VBox>
</ScrollPane>
